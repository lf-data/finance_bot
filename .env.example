# ── LLM (Docker container, OpenAI-compatible API) ─────────────────────────────
LLM_MODEL=your-model-name              # model name exposed by the server
LLM_API_KEY=not-required               # placeholder – used only if server needs it

# ── Tavily Search ──────────────────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key     # https://app.tavily.com/

ANALYSIS_LANGUAGE=italian  # language for the final report (english|italian|...)
SCREENER_WORKERS=6
SCREENER_BENCHMARK=SWDA.MI