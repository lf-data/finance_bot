# ══════════════════════════════════════════════════════════════════════════════
#  VQM Screener — environment variables
#  Copy this file to .env (git-ignored) and fill in your values.
# ══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Required — all screener results are persisted here.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=finanalysis

# ── Screener ──────────────────────────────────────────────────────────────────
# SCREENER_BENCHMARK is the fallback index when no suffix-based mapping applies.
# Suffix auto-detection: .MI→FTSEMIB.MI  .DE/.F/.BE→^GDAXI  .PA→^FCHI
#                        .L→^FTSE  .MC→^IBEX  .SW→^SSMI  .AS→^AEX  no suffix→SPY
SCREENER_BENCHMARK=SWDA.MI

# Main fetch is sequential; this variable is reserved for future use.
SCREENER_WORKERS=6

# Language for optional AI commentary (english | italian | …).
ANALYSIS_LANGUAGE=italian

# ── LLM — optional, required only for --ai flag ───────────────────────────────
# Any OpenAI-compatible endpoint (local Ollama, LM Studio, OpenAI cloud, etc.).
LLM_MODEL=gpt-4o
LLM_API_KEY=sk-...

# ── Tavily Search — optional, required only for --ai flag ─────────────────────
# https://app.tavily.com/
TAVILY_API_KEY=tvly-...
